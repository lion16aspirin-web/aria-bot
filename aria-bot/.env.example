# Discord Bot Token (отримати на https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Anthropic API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Шлях до SQLite бази (за замовчуванням aria.db в папці проекту)
DATABASE_PATH=aria.db

# Назва каналу для статусів (без #)
STATUS_CHANNEL_NAME=org-статус

# Назва каналу для місій (без #)
MISSIONS_CHANNEL_NAME=місії

# UEX Corp API Key — опціонально (https://uexcorp.space/account)
# Без ключа доступні публічні ендпоінти, з ключем — більше даних
UEX_API_KEY=
